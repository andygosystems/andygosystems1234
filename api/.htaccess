RewriteEngine On
# Enable CORS preflight handling
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]

# Route /api/properties and /api/properties/{id} to properties.php
RewriteRule ^properties$ properties.php [L,QSA]
RewriteRule ^properties/([0-9]+)$ properties.php?id=$1 [L,QSA]

# Route /api/upload.php for image uploads
RewriteRule ^upload\.php$ upload.php [L,QSA]

# Auth and images endpoints
RewriteRule ^auth\.php$ auth.php [L,QSA]
RewriteRule ^images\.php$ images.php [L,QSA]
RewriteRule ^tokens\.php$ tokens.php [L,QSA]
RewriteRule ^scrape\.php$ scrape.php [L,QSA]
RewriteRule ^inquiries\.php$ inquiries.php [L,QSA]
RewriteRule ^crm\.php$ crm.php [L,QSA]

# Security headers
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set Referrer-Policy "no-referrer-when-downgrade"
Header always set X-XSS-Protection "1; mode=block"

# Allow CORS for API
Header always set Access-Control-Allow-Origin "*"
Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
Header always set Access-Control-Allow-Headers "Content-Type, Authorization"
